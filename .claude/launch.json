{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "cwd": "backend",
      "runtimeExecutable": "../.venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "frontend",
      "cwd": "frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "simulator",
      "cwd": "simulator",
      "runtimeExecutable": "../.venv/Scripts/python.exe",
      "runtimeArgs": ["main.py", "--demo"],
      "port": 0
    }
  ]
}
